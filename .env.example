# --- Required ---------------------------------------------------------------

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:AA-your-bot-token-here

# Your numeric Telegram user id. ONLY this user may talk to the bot.
# Get it by messaging @userinfobot on Telegram.
ALLOWED_USER_ID=123456789

# --- Optional ---------------------------------------------------------------

# The directory Copilot is allowed to work in (its sandbox).
# Point this at a real project folder. Defaults to ./workspace if empty.
WORKING_DIR=

# Model to use (e.g. claude-sonnet-4.5, gpt-5). Empty = Copilot default.
COPILOT_MODEL=

# Let Copilot run tools without per-action approval (needed for headless use).
ALLOW_ALL_TOOLS=true

# Comma-separated tools Copilot may NEVER use. --deny-tool takes precedence
# over --allow-all-tools, so this is your safety net for destructive commands.
COPILOT_DENY_TOOLS=shell(rm),shell(rmdir),shell(rd),shell(del),shell(Remove-Item),shell(format),shell(git push),shell(sudo),shell(shutdown),shell(reboot)

# Seconds before a single request is killed.
REQUEST_TIMEOUT=900

# Voice notes -> local Whisper transcription (no API key needed). true/false
ENABLE_VOICE=true
# Whisper model: tiny/base/small/medium/large-v3 (bigger = better, slower).
WHISPER_MODEL=small
# Force a language (e.g. ru, en). Empty = auto-detect.
WHISPER_LANGUAGE=

# Keep context across messages via `copilot --continue`. true/false
CONTINUE_SESSION=true

# Reply with a short phone-friendly summary instead of the raw CLI output.
# Toggle at runtime with /brief and /raw, or the menu's Mode button.
SUMMARY_MODE=true
# Override the instruction appended to prompts in brief mode. Empty = built-in default.
SUMMARY_INSTRUCTION=

# --- VS Code bridge (optional) -----------------------------------------------
# Lets the bot send prompts into a real VS Code Copilot Chat window (via the
# extension/ VS Code extension) instead of spawning the headless CLI, and lets
# that chat push status updates back to you on Telegram (notify_telegram tool).
# Toggle at runtime with the menu's Target button (CLI <-> VS Code).
VSCODE_MODE=false
# Local HTTP endpoint the VS Code extension listens on (127.0.0.1 only).
BRIDGE_URL=http://127.0.0.1:8765
# Local port the bot's own notify server listens on for the extension to POST to.
NOTIFY_PORT=8766
# Shared secret between the bot and the extension. Empty = no auth (localhost only).
BRIDGE_TOKEN=
